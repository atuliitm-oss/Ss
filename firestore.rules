rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Teachers collection rules
    match /teachers/{teacherId} {
      allow read: if true; // Everyone can see teachers for identification
      allow write: if true; // Temporary: should be restricted in production
    }

    // Attendance records rules
    match /attendance/{recordId} {
      allow read: if true;
      allow create: if true;
      allow delete: if true;
    }

    // Configuration rules
    match /config/{configId} {
      allow read: if true; // Needed for kiosk to get AI settings
      allow write: if true; // Temporary: should be restricted to admins
    }

    // Counter rules
    match /counters/{counterId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
